# Large raw data files (too big for GitHub)
data/raw/

# Movie poster images (large binary cache, regenerated from data sources)
static/posters/
# TMDB downloader failure logs (regenerated on every run)
static/tmdb_*_download_failures.log
static/tmdb_download_failures.log

# Dead processed files — not referenced at runtime
# movies_clean.csv was superseded by movies_final_clean.csv (see data_loader.py:45);
# imdb_id.csv was the legacy crawler's input list, kept only for reference.
data/processed/movies_clean.csv
data/processed/imdb_id.csv

# Legacy IMDb crawler output binaries — code archived in _legacy_imdb_crawler/
# stays in git so the pipeline is reproducible, but the sqlite + csv artifacts
# can be regenerated by re-running the crawler.
static/_legacy_imdb_crawler/*.db
static/_legacy_imdb_crawler/imdb_posters_url.csv

# Team research artifacts — large data files archived under notebooks/team_research/.
# The notebooks themselves stay in git; the CSVs and any regenerated similarity
# matrices do not (see notebooks/team_research/README.md).
notebooks/team_research/*.csv
*.pkl

